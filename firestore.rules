rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return isAuth() ? userDoc().data.role : null;
    }

    function isAdmin() {
      // Email fallback handles bootstrap (first admin doc creation, when userRole() can't read yet).
      // Short-circuit: if email matches, don't call userRole() which would throw on missing doc.
      return (isAuth() && request.auth.token.email == 'admin@dragonswim.com')
          || userRole() == 'admin';
    }

    // ── contacts — public contact form submissions ───────────────

    match /contacts/{docId} {
      // Anyone (even unauthenticated visitors) can submit
      allow create: if true;
      // Submissions are private — no public read/update/delete
      allow read, update, delete: if false;
    }

    // ── users — profile documents keyed by Auth UID ──────────────

    match /users/{uid} {
      // Users can read their own profile; admins can read any
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());

      // Users create their own profile (normal signup or bootstrap admin)
      allow create: if isAuth() && request.auth.uid == uid;
      // Admins can create users with any role (e.g., creating coaches)
      allow create: if isAdmin();

      // Users can update their own profile but CANNOT change their role
      allow update: if isAuth() && request.auth.uid == uid
                    && request.resource.data.role == resource.data.role;
      // Admins can update any user profile
      allow update: if isAdmin();

      // User documents cannot be deleted through the client SDK
      allow delete: if false;
    }

    // ── registrations — family registration data ─────────────────

    match /registrations/{uid} {
      // Any authenticated user can read (needed for spouse email lookup)
      allow read: if isAuth();

      // Owner creates their own; admin can create any
      allow create: if isAuth() && request.auth.uid == uid;

      // Owner, editors (spouse), parentEmails match, and admin can update
      allow update: if isAuth() && (
        request.auth.uid == uid ||
        request.auth.uid in resource.data.editors ||
        request.auth.token.email in resource.data.parentEmails ||
        isAdmin()
      );

      // Soft-delete only (done via update), never hard-delete from client
      allow delete: if false;
    }

    // ── coaches — pre-authorized coach emails (public read for signup check) ─

    match /coaches/{docId} {
      // Anyone can check if their email is authorized (used during sign-up)
      allow read: if true;
      // Only admins can create or delete coach docs
      allow create, delete: if isAdmin();
      // Admin: full update. Authorized user: only status + registeredUid.
      allow update: if isAdmin() || (
        isAuth() &&
        request.auth.token.email != null &&
        request.auth.token.email == resource.data.email &&
        // lock down: non-admin can only change status and registeredUid
        request.resource.data.email == resource.data.email &&
        request.resource.data.displayName == resource.data.displayName &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.createdBy == resource.data.createdBy
      );
    }

    // ── meets — swim meets (admin-managed, coach read-only) ─────

    match /meets/{docId} {
      // All authenticated users can view meets
      allow read: if isAuth();
      // Only admins can create, update, or delete meets
      allow create, update, delete: if isAdmin();
    }

    // ── schedules — practice schedules (admin-managed, coach read-only) ─

    match /schedules/{docId} {
      // All authenticated users can view schedules
      allow read: if isAuth();
      // Only admins can create, update, or delete
      // (includes CSV batch import via writeBatch)
      allow create, update, delete: if isAdmin();
    }

    // ── families — pre-authorized family emails (public read for signup check) ─

    match /families/{docId} {
      // Anyone can check if their email is authorized (used during sign-up)
      allow read: if true;
      // Only admins can add/remove authorized families
      allow create, delete: if isAdmin();
      // Admin: full update. Authorized user: only status + registeredUid.
      allow update: if isAdmin() || (
        isAuth() &&
        request.auth.token.email != null &&
        request.auth.token.email == resource.data.email &&
        // lock down: non-admin can only change status and registeredUid
        request.resource.data.email == resource.data.email &&
        request.resource.data.parentName == resource.data.parentName &&
        request.resource.data.createdBy == resource.data.createdBy
      );
    }

    // ── deposits — swimmer deposit tracking (coach/admin-managed) ─

    match /deposits/{docId} {
      // All authenticated users can view deposits
      allow read: if isAuth();
      // Only coaches and admins can create, update, or delete deposits
      allow create, update, delete: if isAdmin();
    }

    // ── members — test utility only, deny all in production ──────

    match /members/{docId} {
      allow read, write: if false;
    }
  }
}
